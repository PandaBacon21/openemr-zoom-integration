# ─── Encryption ────────────────────────────────────────────────────────────────
# Dedicated key for encrypting sensitive data at rest (secrets, tokens).
# NEVER use SECRET_KEY for this — they must be independent.
# WARNING: Changing this key requires running the key rotation migration script
# before restarting the app, or all encrypted data becomes unreadable.
ENCRYPTION_KEY=super-secret-encryption-key
KEYS_BASE_DIR=/app/keys

# ─── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=true

# ─── Integration Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:////app/data/integration.db

# ─── OpenEMR Admin ────────────────────────────────────────────────────────────
OPENEMR_ADMIN_USER=admin
OPENEMR_ADMIN_PASS=change-me-admin

# ─── MariaDB for OpenEMR ──────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-db-root
OPENEMR_DB_USER=openemr
OPENEMR_DB_PASS=change-me-db-openemr
OPENEMR_DB_HOST=mariadb
OPENEMR_DB_PORT=3306
OPENEMR_DB_NAME=openemr

# ─── OpenEMR URLs ─────────────────────────────────────────────────────────────
# Internal OpenEMR base URL used by the Flask app
OPENEMR_BASE_URL=http://openemr:80
# The public HTTPS URL of OpenEMR 
# Used as the OAuth2 issuer URL (OPENEMR_SETTING_site_addr_oath).
# Must match exactly what Flask uses when validating OpenEMR tokens.
OPENEMR_PUBLIC_URL=https://openemr-public-domain.com
OPENEMR_FHIR_BASE_URL=https://openemr-public-domain.com/apis/default/fhir
OPENEMR_SCOPES=system/Patient.read system/Appointment.read system/Encounter.read

# ── OpenEMR/Flask ────────────────────────────────────────────
# Internal for OpenEMR -> Flask Notifications
OPENEMR_FLASK_SECRET=your-strong-secret-here

# ─── Public-facing URL of the Flask app ───────────────────────────────────────
# Public URL (currently not used in dynamic registration payload)
APP_PUBLIC_URL=https://flask-integration-public-domain.com
# Internal URL OpenEMR reaches on the Docker network; used for JWKS/callback URIs
APP_INTERNAL_URL=http://zoom-bridge:5000

# ── Logging ────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FILE=./logs/zoomly.log

# ── Admin Config UI Auth ────────────────────────────────
# Password used by POST /api/auth/login.
CONFIG_ADMIN_PASSWORD=change-me-admin-config-password
# Secret used to sign config/admin JWTs. Use a long random value.
CONFIG_JWT_SECRET=change-me-to-a-long-random-jwt-signing-secret
